# SkyBooker production Nginx server block template
# Usage: copy to /etc/nginx/sites-available/skybooker.conf,
# replace <placeholders> with actual values, then enable the site.

server {
    listen 80;
    server_name <your-domain.example.com>;

    # Health check — public
    location /healthz {
        proxy_pass http://127.0.0.1:8088/healthz;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API (exact match for /api without trailing slash)
    location = /api {
        proxy_pass http://127.0.0.1:8088/api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backend API (prefix match for /api/*)
    location /api/ {
        proxy_pass http://127.0.0.1:8088/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend — uncomment when frontend service is available
    # location / {
    #     proxy_pass http://127.0.0.1:3000/;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
}

# Uncomment after running: sudo certbot --nginx -d <your-domain.example.com>
# Certbot will add the HTTPS server block and redirect rules automatically.
